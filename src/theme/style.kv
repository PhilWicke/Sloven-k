# Slovenčk Theme — Gemini-designed, hand-tuned for Kivy
# Primary green: (0.345, 0.8, 0.008, 1)  ~#58CC02
# Secondary blue: (0.11, 0.69, 0.965, 1)  ~#1CB0F6
# Background: (0.969, 0.969, 0.969, 1)  ~#F7F7F7
# Error red: (1, 0.294, 0.294, 1)  ~#FF4B4B

<RoundedButton@Button>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    font_size: '18sp'
    bold: True
    size_hint_y: None
    height: '52dp'
    canvas.before:
        Color:
            rgba: (0.345, 0.8, 0.008, 1) if self.state == 'normal' else (0.275, 0.64, 0.006, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

<SecondaryButton@Button>:
    background_normal: ''
    background_down: ''
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    font_size: '18sp'
    size_hint_y: None
    height: '52dp'
    canvas.before:
        Color:
            rgba: (0.11, 0.69, 0.965, 1) if self.state == 'normal' else (0.088, 0.55, 0.77, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

<CardBox@BoxLayout>:
    orientation: 'vertical'
    padding: dp(15)
    spacing: dp(10)
    canvas.before:
        Color:
            rgba: 0, 0, 0, 0.06
        RoundedRectangle:
            pos: self.x + dp(1), self.y - dp(2)
            size: self.width, self.height
            radius: [dp(12)]
        Color:
            rgba: 1, 1, 1, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

<TitleLabel@Label>:
    font_size: '28sp'
    bold: True
    color: 0.15, 0.15, 0.15, 1
    halign: 'center'
    valign: 'middle'
    text_size: self.size

<BodyLabel@Label>:
    font_size: '20sp'
    color: 0.25, 0.25, 0.25, 1
    halign: 'center'
    valign: 'middle'
    text_size: self.size

<AppTextInput@TextInput>:
    font_size: '20sp'
    multiline: False
    size_hint_y: None
    height: '52dp'
    padding: [dp(15), dp(12), dp(15), dp(12)]
    background_color: 1, 1, 1, 1
    foreground_color: 0, 0, 0, 1
    cursor_color: 0.345, 0.8, 0.008, 1
